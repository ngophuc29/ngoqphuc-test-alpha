# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Assistant ID (optional)
# If provided, the script will automatically attach the created/updated Vector Store to this Assistant
OPENAI_ASSISTANT_ID=asst_your_assistant_id_here

# Zendesk Help Center Articles API URL (optional, defaults to support.optisigns.com)
ZENDESK_URL=https://support.optisigns.com/api/v2/help_center/en-us/articles.json

# Minimum number of articles to scrape (optional, defaults to 30)
ARTICLE_LIMIT=30
