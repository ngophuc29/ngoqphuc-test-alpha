# Gemini API Key (required)
# Obtain a free key from https://aistudio.google.com/
API_KEY=your_gemini_api_key_here

# Zendesk Help Center Articles API URL (optional, defaults to support.optisigns.com)
ZENDESK_URL=https://support.optisigns.com/api/v2/help_center/en-us/articles.json

# Minimum number of articles to scrape (optional, defaults to 30)
ARTICLE_LIMIT=30
